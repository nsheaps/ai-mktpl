{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "commit": false,
    "tag": false,
    "push": false,
    "requireCleanWorkingDir": false,
    "requireUpstream": false,
    "getLatestTagFromAllRefs": false
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  },
  "hooks": {
    "after:bump": "prettier --write .claude-plugin/plugin.json || true"
  },
  "increment": "patch"
}
