{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claude-agent-payload.schema.json",
  "title": "Claude Agent Dispatch Payload",
  "description": "Schema for repository_dispatch client_payload sent to claude-agent workflow",
  "type": "object",
  "required": ["trigger", "source", "author"],
  "properties": {
    "trigger": {
      "type": "object",
      "description": "Information about what triggered this dispatch",
      "required": ["event", "type", "action"],
      "properties": {
        "event": {
          "type": "string",
          "enum": ["mention", "issueCreated"],
          "description": "The logical event type - determines which prompt template to use"
        },
        "type": {
          "type": "string",
          "enum": ["issue_comment", "pull_request_review_comment", "pull_request_review", "issues"],
          "description": "The GitHub event type that triggered this"
        },
        "action": {
          "type": "string",
          "enum": ["created", "edited", "submitted", "opened", "assigned", "labeled"],
          "description": "The action that occurred"
        }
      }
    },
    "source": {
      "type": "object",
      "description": "Where this was triggered from",
      "required": ["repo"],
      "properties": {
        "title": {
          "type": ["string", "null"],
          "description": "Issue/PR title"
        },
        "html_url": {
          "type": "string",
          "description": "URL to the issue or PR"
        },
        "repo": {
          "type": "string",
          "description": "Repository full name (owner/repo)"
        },
        "issue_or_pr_number": {
          "type": ["integer", "null"],
          "description": "Issue or PR number"
        },
        "is_pr": {
          "type": "boolean",
          "description": "Whether this is a pull request (true) or issue (false)"
        },
        "ref": {
          "type": "string",
          "description": "Git ref (branch) context"
        }
      }
    },
    "author": {
      "type": "object",
      "description": "Who triggered this",
      "required": ["login"],
      "properties": {
        "login": {
          "type": "string",
          "description": "GitHub username"
        },
        "association": {
          "type": "string",
          "enum": [
            "OWNER",
            "MEMBER",
            "COLLABORATOR",
            "CONTRIBUTOR",
            "FIRST_TIME_CONTRIBUTOR",
            "FIRST_TIMER",
            "NONE"
          ],
          "description": "Author's association with the repository"
        }
      }
    },
    "mention": {
      "type": "object",
      "description": "Data specific to mention events (trigger.event = 'mention')",
      "properties": {
        "comment_id": {
          "type": ["integer", "null"],
          "description": "Comment or review ID that triggered this"
        },
        "body": {
          "type": "string",
          "description": "Full body text of the comment/review/issue containing the @claude mention"
        }
      }
    },
    "issueCreated": {
      "type": "object",
      "description": "Data specific to issueCreated events (trigger.event = 'issueCreated')",
      "properties": {
        "body": {
          "type": "string",
          "description": "Full body text of the newly created issue"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "trigger": { "properties": { "event": { "const": "mention" } } } }
      },
      "then": {
        "required": ["mention"]
      }
    },
    {
      "if": {
        "properties": { "trigger": { "properties": { "event": { "const": "issueCreated" } } } }
      },
      "then": {
        "required": ["issueCreated"]
      }
    }
  ]
}
