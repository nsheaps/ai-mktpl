{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:*.github.com)",
      "WebFetch(domain:*.githubusercontent.com)",
      "WebFetch(domain:cursor.com)",
      "WebFetch(domain:*.cursor.com)",
      "WebFetch(domain:anthropic.com)",
      "WebFetch(domain:*.anthropic.com)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:*.claude.com)",
      "WebFetch(domain:claude.ai)",
      "WebFetch(domain:*.claude.ai)",
      "WebFetch(domain:code.visualstudio.com)",
      "WebFetch(domain:*.weather.gov)",

      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git rev-parse:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",

      "Bash(brew search:*)",
      "Bash(brew info:*)",

      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",

      "Bash(wc:*)",
      "Bash(man:*)"
    ],
    "deny": ["Bash(rm -rf /:*)"],
    "ask": ["Bash(rm -rf .:*)"]
  }
}
