{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "anthropics-claude-code": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    }
  },
  "enabledPlugins": {
    "agent-sdk-dev@anthropics-claude-code": true,
    "code-review@anthropics-claude-code": true,
    "pr-review-toolkit@anthropics-claude-code": true,
    "plugin-dev@anthropics-claude-code": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/PreToolUse/ensure-write-dir.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/SessionStart/hook.sh startup",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/SessionStart/hook.sh resume",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "attribution": {
    "commit": "\nCo-Authored-By: Claude Code (${CLAUDE_PROJECT_DIR}) <noreply@anthropic.com>",
    "pullRequests": "\nCo-Authored-By: Claude Code (${CLAUDE_PROJECT_DIR}) <noreply@anthropic.com>"
  },
  "permissions": {
    "allow": [
      "Skill",
      "SlashCommand",
      "WebSearch",
      "Glob",
      "Grep",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:*.github.com)",
      "WebFetch(domain:*.githubusercontent.com)",
      "WebFetch(domain:cursor.com)",
      "WebFetch(domain:*.cursor.com)",
      "WebFetch(domain:anthropic.com)",
      "WebFetch(domain:*.anthropic.com)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:*.claude.com)",
      "WebFetch(domain:claude.ai)",
      "WebFetch(domain:*.claude.ai)",
      "WebFetch(domain:code.visualstudio.com)",
      "WebFetch(domain:*.weather.gov)",
      "WebFetch(domain:mise.run)",
      "WebFetch(domain:*.mise.run)",
      "WebFetch(domain:just.systems)",

      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git rev-parse:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",
      "Bash(git remote get-url:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",

      "Bash(brew search:*)",
      "Bash(brew info:*)",

      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",

      "Bash(wc:*)",
      "Bash(man:*)",

      "Bash(just:*)",
      "Bash(mise:*)",
      "Bash(yarn:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(chmod:*)",
      "Bash(readlink:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(mkdir:*)"
    ],
    "ask": [
      "Bash(gh pr view --web:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --force-if-includes:*)"
    ]
  }
}
