{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "PATH": "${HOME}/.local/share/mise/shims:${HOME}/.local/bin:${PATH}"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start.sh",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
