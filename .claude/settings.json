{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/SessionStart/hook.sh startup",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/SessionStart/hook.sh resume",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:*.github.com)",
      "WebFetch(domain:*.githubusercontent.com)",
      "WebFetch(domain:cursor.com)",
      "WebFetch(domain:*.cursor.com)",
      "WebFetch(domain:anthropic.com)",
      "WebFetch(domain:*.anthropic.com)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:*.claude.com)",
      "WebFetch(domain:claude.ai)",
      "WebFetch(domain:*.claude.ai)",
      "WebFetch(domain:code.visualstudio.com)",
      "WebFetch(domain:*.weather.gov)",
      "WebFetch(domain:mise.run)",
      "WebFetch(domain:*.mise.run)",

      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git rev-parse:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",

      "Bash(brew search:*)",
      "Bash(brew info:*)",

      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",

      "Bash(wc:*)",
      "Bash(man:*)"
    ],
    "deny": ["Bash(rm -rf /:*)"],
    "ask": [
      "Bash(gh pr view --web:*)",
      "Bash(rm -rf .:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --force-if-includes:*)"
    ]
  }
}
