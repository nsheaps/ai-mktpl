{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "\nCo-Authored-By: Claude Code (${CLAUDE_PROJECT_DIR/$HOME/~}) <noreply@anthropic.com>"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Skill",
      "Agent",
      "SlashCommand",
      "WebSearch",
      "Glob",
      "Grep",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:*.github.com)",
      "WebFetch(domain:*.githubusercontent.com)",
      "WebFetch(domain:cursor.com)",
      "WebFetch(domain:*.cursor.com)",
      "WebFetch(domain:anthropic.com)",
      "WebFetch(domain:*.anthropic.com)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:*.claude.com)",
      "WebFetch(domain:claude.ai)",
      "WebFetch(domain:*.claude.ai)",
      "WebFetch(domain:code.visualstudio.com)",
      "WebFetch(domain:*.weather.gov)",
      "WebFetch(domain:mise.run)",
      "WebFetch(domain:*.mise.run)",
      "WebFetch(domain:just.systems)",
      "WebFetch(domain:developer.1password.com)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git rev-parse:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",
      "Bash(git remote get-url:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(brew search:*)",
      "Bash(brew info:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(wc:*)",
      "Bash(man:*)",
      "Bash(just:*)",
      "Bash(mise:*)",
      "Bash(yarn:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(chmod:*)",
      "Bash(readlink:*)",
      "mcp__memory__*"
    ],
    "deny": ["Bash(rm -rf /:*)"],
    "ask": [
      "Bash(gh pr view --web:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --force-if-includes:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-hook.sh pre-tool-use"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-hook.sh post-tool-use"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": false,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "data-serialization@nsheaps-claude-plugins": true,
    "todo-sync@nsheaps-claude-plugins": true,
    "mise@nsheaps-claude-plugins": true,
    "gh-tool@nsheaps-claude-plugins": true,
    "permissions-sync@nsheaps-claude-plugins": true,
    "sequential-thinking@nsheaps-claude-plugins": true,
    "correct-behavior@nsheaps-claude-plugins": true,
    "common-sense@nsheaps-claude-plugins": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "nsheaps-claude-plugins": {
      "source": {
        "source": "github",
        "path": "nsheaps/ai-mktpl"
      }
    }
  }
}
