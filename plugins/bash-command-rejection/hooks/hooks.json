{
  "description": "Rejects bash commands with && or | chaining to ensure proper permission handling",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/reject-chained-commands.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
