{
  "description": "Install/update mise on session start for web sessions",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/install-mise.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
