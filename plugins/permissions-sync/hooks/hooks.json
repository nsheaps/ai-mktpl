{
  "description": "Merge permission scopes from source settings into settings.local.json on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/sync-permissions.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
