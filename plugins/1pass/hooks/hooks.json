{
  "description": "Install/update 1Password CLI and op-exec on session start for web sessions",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/install-op.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
