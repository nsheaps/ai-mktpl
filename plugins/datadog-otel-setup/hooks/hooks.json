{
  "description": "Configure OTEL environment variables for Datadog on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/configure-otel.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
