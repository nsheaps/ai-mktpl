{
  "description": "Configure Claude Code's OTEL integration for Datadog at session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start-otel-setup.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
