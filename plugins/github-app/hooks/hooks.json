{
  "description": "Generate initial GitHub App installation token on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/github-token-init.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
