{
  "description": "Check for gs-stack-status installation on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-gs-stack-status.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
