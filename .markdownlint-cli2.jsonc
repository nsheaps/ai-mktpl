    "MD033": false,
    "MD034": false,
    "MD041": false,
    "MD032": false,
    "MD022": false,
    "MD040": false,
    "MD060": false
  },
  "globs": ["**/*.md"],
  "ignores": ["node_modules/**", "**/node_modules/**", ".git/**"]
}
