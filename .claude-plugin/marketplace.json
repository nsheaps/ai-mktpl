{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "nsheaps/claude-marketplace",
  "owner": {
    "name": "Nathan Heaps",
    "email": "nsheaps@gmail.com"
  },
  "metadata": {
